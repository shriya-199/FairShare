{
  "name": "fairshare",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.9.0",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev:server": "pnpm --filter fairshare-server dev",
    "dev:client": "pnpm --filter fairshare-client dev",
    "build": "pnpm --filter fairshare-client build && pnpm --filter fairshare-server build",
    "start": "pnpm --filter fairshare-server start",
    "test": "pnpm --filter fairshare-server test",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  }
}
